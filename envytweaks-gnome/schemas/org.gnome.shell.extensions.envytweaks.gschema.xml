<schemalist gettext-domain="envytweaks">
  <schema id="org.gnome.shell.extensions.envytweaks"
      path="/org/gnome/shell/extensions/envytweaks/">

    <key name="force-topbar-view" type="b">
      <default>false</default>
        <summary>Enable Force To Topbar View?</summary>
        <description>
            If true, the extension view will be placed in topbar in any case.
        </description>
    </key>

    <key name="rtd3" type="b">
      <default>true</default>
        <summary>Enable RTD3 Power Management?</summary>
        <description>
            If true, envytweaks set the RTD3 Power Management flag enabled
        </description>
    </key>

    <key name="rtd3-mode" type="i">
      <default>2</default>
        <summary>RTD3 Power Management Mode</summary>
        <description>
            0 = Disabled, 1 = Fine-Grained, 2 = Coarse-Grained, 3 = Aggressive
        </description>
    </key>

    <key name="force-composition-pipeline" type="b">
      <default>true</default>
        <summary>Enable ForceCompositionPipeline?</summary>
        <description>
            If true, envytweaks set the ForceCompositionPipeline flag enabled
        </description>
    </key>

    <key name="coolbits" type="b">
      <default>false</default>
        <summary>Enable Coolbits?</summary>
        <description>
            If true, envytweaks set the Coolbits flag enabled
        </description>
    </key>

  </schema>
</schemalist>
