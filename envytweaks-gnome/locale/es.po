#: envytweaks-gnome/prefs.js:12
msgid "General"
msgstr "General"

#: envytweaks-gnome/prefs.js:17
msgid "Settings"
msgstr "Ajustes"

#: envytweaks-gnome/prefs.js:18
msgid "Adjust extension and GPU profile switching options"
msgstr "Ajustar las opciones de la extensión y del cambio de perfil de GPU"

#: envytweaks-gnome/prefs.js:22
msgid "RTD3"
msgstr "RTD3"

#: envytweaks-gnome/prefs.js:23
msgid ""
"Enable PCI-Express Runtime D3 (RTD3) Power Management on Hybrid mode. When "
"not disabled, RTD3 allows the dGPU to be dynamically turned off when not in "
"use"
msgstr ""
"Habilitar la gestión de energía PCI-Express Runtime D3 (RTD3) en modo híbrido. "
"Cuando no está deshabilitado, RTD3 permite apagar dinámicamente la dGPU "
"cuando no está en uso"

#: envytweaks-gnome/prefs.js:27
msgid "RTD3 Power Management Mode"
msgstr "Modo de Gestión de Energía RTD3"

#: envytweaks-gnome/prefs.js:28
msgid ""
"Select the level of PCI-Express Runtime D3 Power Management (default is "
"Coarse-Grained)"
msgstr ""
"Seleccione el nivel de gestión de energía PCI-Express Runtime D3 "
"(el valor predeterminado es Coarse-Grained)"

#: envytweaks-gnome/prefs.js:30
msgid "0: Disabled"
msgstr "0: Deshabilitado"

#: envytweaks-gnome/prefs.js:31
msgid "1: Fine-Grained"
msgstr "1: Fino (Fine-Grained)"

#: envytweaks-gnome/prefs.js:32
msgid "2: Coarse-Grained (Default)"
msgstr "2: Grueso (Coarse-Grained - Por Defecto)"

#: envytweaks-gnome/prefs.js:33
msgid "3: Aggressive"
msgstr "3: Agresivo (Ampere+)"

#: envytweaks-gnome/prefs.js:38
msgid "Force Composition Pipeline"
msgstr "Forzar Pipeline de Composición (Force Composition Pipeline)"

#: envytweaks-gnome/prefs.js:39
msgid ""
"Enable ForceCompositionPipeline on Nvidia mode. Use this option if facing "
"screen tearing"
msgstr ""
"Habilitar ForceCompositionPipeline en modo Nvidia. Use esta opción si experimenta fragmentación de pantalla (screen tearing)"

#: envytweaks-gnome/prefs.js:43
msgid "Coolbits"
msgstr "Coolbits"

#: envytweaks-gnome/prefs.js:44
msgid ""
"Enable Coolbits, which allows overclocking on Nvidia mode (not recommended)"
msgstr ""
"Habilitar Coolbits, lo que permite overclocking en modo Nvidia (no recomendado)"

#: envytweaks-gnome/prefs.js:48
msgid "Force Topbar View"
msgstr "Forzar Vista en Barra Superior"

#: envytweaks-gnome/prefs.js:49
msgid ""
"Show the GPU profile selector directly in the panel/topbar instead of the "
"Quick Settings menu"
msgstr ""
"Mostrar el selector de perfiles de GPU directamente en el panel superior en lugar de en el menú de Ajustes Rápidos"

#: envytweaks-gnome/ui/QuickSettingsView.js:28
msgid "GPU Profile"
msgstr "Perfil de GPU"

#: envytweaks-gnome/ui/QuickSettingsView.js:29
msgid "Not Installed"
msgstr "No Instalado"

#: envytweaks-gnome/ui/QuickSettingsView.js:38
#: envytweaks-gnome/ui/TopBarView.js:65
msgid "envytweaks is not installed!"
msgstr "¡envytweaks no está instalado!"

#: envytweaks-gnome/ui/QuickSettingsView.js:40
#: envytweaks-gnome/ui/QuickSettingsView.js:104
#: envytweaks-gnome/ui/QuickSettingsView.js:125
msgid "Choose a GPU mode"
msgstr "Elige un modo de GPU"

#: envytweaks-gnome/ui/QuickSettingsView.js:46
#: envytweaks-gnome/ui/TopBarView.js:39
msgid "Integrated"
msgstr "Integrado (Integrated)"

#: envytweaks-gnome/ui/QuickSettingsView.js:46
#: envytweaks-gnome/ui/QuickSettingsView.js:55
#: envytweaks-gnome/ui/QuickSettingsView.js:64
msgid " (Active)"
msgstr " (Activo)"

#: envytweaks-gnome/ui/QuickSettingsView.js:49
#: envytweaks-gnome/ui/QuickSettingsView.js:58
#: envytweaks-gnome/ui/QuickSettingsView.js:67
msgid "Switching..."
msgstr "Cambiando..."

#: envytweaks-gnome/ui/QuickSettingsView.js:50
msgid "Switching to Integrated mode..."
msgstr "Cambiando a modo Integrado..."

#: envytweaks-gnome/ui/QuickSettingsView.js:55
#: envytweaks-gnome/ui/TopBarView.js:44
msgid "Hybrid"
msgstr "Híbrido (Hybrid)"

#: envytweaks-gnome/ui/QuickSettingsView.js:59
msgid "Switching to Hybrid mode..."
msgstr "Cambiando a modo Híbrido..."

#: envytweaks-gnome/ui/QuickSettingsView.js:64
#: envytweaks-gnome/ui/TopBarView.js:49
msgid "Nvidia"
msgstr "Nvidia"

#: envytweaks-gnome/ui/QuickSettingsView.js:68
msgid "Switching to Nvidia mode..."
msgstr "Cambiando a modo Nvidia..."

#: envytweaks-gnome/ui/QuickSettingsView.js:84
msgid "More Settings"
msgstr "Más Ajustes"

#: envytweaks-gnome/ui/QuickSettingsView.js:101
#: envytweaks-gnome/ui/QuickSettingsView.js:130
#, javascript-format
msgid "Restart to apply %s mode"
msgstr "Reiniciar para aplicar modo %s"

#: envytweaks-gnome/ui/QuickSettingsView.js:113
msgid "Error"
msgstr "Error"

#: envytweaks-gnome/ui/QuickSettingsView.js:114
#, javascript-format
msgid "Switching failed (code %s)"
msgstr "Fallo al cambiar (código %s)"

#: envytweaks-gnome/ui/TopBarView.js:149
msgid "Restart Required*"
msgstr "Reinicio Requerido*"
